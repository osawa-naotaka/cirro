{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true,
        "noEmit": true,
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "types": ["bun", "vite/client"]
    },
    "include": ["src", "scripts", "vite.config.ts"]
}
