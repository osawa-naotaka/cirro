{
    "name": "@cirro-examples/blog",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "prepare": "panda codegen",
        "dev": "concurrently -k -n css,cirro \"panda cssgen --watch -o public/styles.css\" \"cirro dev\"",
        "typecheck": "tsc",
        "build": "panda cssgen --minify -o public/styles.css && tsc && cirro build",
        "preview": "vite preview"
    },
    "dependencies": {
        "cirro": "workspace:*",
        "gray-matter": "4.0.3",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "rehype-slug": "6.0.0",
        "rehype-stringify": "10.0.1",
        "remark-gfm": "4.0.1",
        "remark-parse": "11.0.0",
        "remark-rehype": "11.1.2",
        "unified": "11.0.5"
    },
    "devDependencies": {
        "@pandacss/dev": "1.11.3",
        "@types/react": "19.2.17",
        "concurrently": "10.0.3",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.2",
        "typescript": "6.0.3",
        "vite": "8.0.16"
    }
}
